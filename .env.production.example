# Docker host bindings. Kept on localhost so existing public services are not affected.
FRONTEND_BIND_HOST=127.0.0.1
FRONTEND_PORT=18480
BACKEND_BIND_HOST=127.0.0.1
BACKEND_PORT=18481

# Public URL used at frontend build time. For Nginx same-domain proxy, use https://your-domain.com
VITE_API_BASE_URL=https://your-domain.com

# Backend runtime
NODE_ENV=production
PORT=4000
HOST=0.0.0.0
DATABASE_URL=postgresql://fkh:CHANGE_ME_DB_PASSWORD@postgres:5432/fkh
JWT_ACCESS_SECRET=CHANGE_ME_LONG_RANDOM_ACCESS_SECRET_AT_LEAST_32_CHARS
JWT_REFRESH_SECRET=CHANGE_ME_LONG_RANDOM_REFRESH_SECRET_AT_LEAST_32_CHARS
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_DAYS=30
CORS_ORIGINS=https://your-domain.com
PUBLIC_API_URL=https://your-domain.com
PUBLIC_CDN_URL=

# Database container credentials. POSTGRES_PASSWORD must match DATABASE_URL password.
POSTGRES_DB=fkh
POSTGRES_USER=fkh
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD

# Telegram integration
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_WEBHOOK_URL=https://your-domain.com/api/v1/telegram/webhook
TELEGRAM_WEBHOOK_SECRET=CHANGE_ME_LONG_RANDOM_TELEGRAM_WEBHOOK_SECRET
TELEGRAM_LOGIN_REQUEST_TTL_SECONDS=300
TELEGRAM_ADMIN_CHAT_ID=
TELEGRAM_ADMIN_IDS=
ORDER_NOTIFICATIONS_ENABLED=false

# Crypto payments. Default production mode is no-KYC self-custody.
CRYPTO_BTC_ADDRESSES=
CRYPTO_USDT_ERC20_ADDRESSES=
CRYPTO_USDT_TRC20_ADDRESSES=
CRYPTO_USDC_ERC20_ADDRESSES=
CRYPTO_PAYMENT_TTL_MINUTES=120
CRYPTO_BTC_PAYMENT_TTL_MINUTES=360
CRYPTO_ETH_TOKEN_PAYMENT_TTL_MINUTES=90
CRYPTO_TRON_PAYMENT_TTL_MINUTES=45
CRYPTO_POLL_INTERVAL_SECONDS=60
CRYPTO_BTC_CONFIRMATIONS=1
CRYPTO_ETH_CONFIRMATIONS=12
CRYPTO_TRON_CONFIRMATIONS=20
COINGECKO_API_URL=https://api.coingecko.com/api/v3
MEMPOOL_API_URL=https://mempool.space/api
ETHERSCAN_API_URL=https://api.etherscan.io/v2/api
ETHERSCAN_API_KEY=
TRONGRID_API_URL=https://api.trongrid.io
TRONGRID_API_KEY=

# Compliance switches
AGE_GATE_ENABLED=false
REGION_RESTRICTIONS_ENABLED=false
